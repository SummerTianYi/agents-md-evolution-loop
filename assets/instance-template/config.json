{
  "schema_version": 2,
  "active_agents_path": "{{ACTIVE_AGENTS_PATH}}",
  "timezone": "{{TIMEZONE}}",
  "report_language": "zh-CN",
  "schedule": {
    "weekdays": ["MO", "TU", "WE", "TH", "FR"],
    "times": ["10:00", "17:00"]
  },
  "auto_install": false,
  "approval_channel": "codex",
  "approval_phrase": "批准安装 run <Run ID>",
  "author_reasoning_effort": "max",
  "reviewer_reasoning_effort": "max",
  "routine_check_reasoning_effort": "low",
  "require_detected_model_as_author": true,
  "require_fresh_sessions": true,
  "require_independent_reviewer": true,
  "max_pending_candidates_per_model": 1,
  "official_source_check_required": true,
  "official_sources": [
    "https://developers.openai.com/codex/models",
    "https://developers.openai.com/codex/changelog"
  ],
  "test_trigger_path": "test-trigger.json",
  "preference_profile": "{{PREFERENCE_PROFILE}}"
}
